local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")
local isMobile = game:GetService("UserInputService").TouchEnabled

if _G.Name_Active then
    _G.Name_Active = false
    for _, v in pairs(Workspace:GetDescendants()) do
        if v.Name == "VENENO_NAME" then pcall(function() v:Destroy() end) end
    end
    return
end

_G.Name_Active = true

local function apply(char)
    if not char or char:FindFirstChild("VENENO_NAME") or char.Name == Players.LocalPlayer.Name then return end
    local hum = char:FindFirstChildWhichIsA("Humanoid")
    if not hum then return end

    local c = Instance.new("Folder", char)
    c.Name = "VENENO_NAME"

    local high = Instance.new("Highlight", c)
    high.FillTransparency = 1
    high.OutlineColor = Color3.new(0, 1, 0)
    high.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    high.Adornee = char

    local att = Instance.new("Attachment", char:FindFirstChild("HumanoidRootPart"))
    att.Name = "VENENO_NAME"
    att.Position = Vector3.new(0, 4, 0)

    local bill = Instance.new("BillboardGui", c)
    bill.Name = "VENENO_NAME"
    bill.Size = UDim2.new(0, 150, 0, 50)
    bill.AlwaysOnTop = true
    bill.Adornee = att

    local list = Instance.new("UIListLayout", bill)
    list.HorizontalAlignment = Enum.HorizontalAlignment.Center
    list.SortOrder = Enum.SortOrder.LayoutOrder
    list.Padding = UDim.new(0, 2)

    local function createLabel(col, order, size)
        local l = Instance.new("TextLabel", bill)
        l.Size = UDim2.new(1, 0, 0, size)
        l.BackgroundTransparency = 1
        l.Font = Enum.Font.Arcade
        l.TextSize = isMobile and 10 or 12
        l.TextColor3 = col
        l.TextStrokeTransparency = 0
        l.LayoutOrder = order
        return l
    end

    local nL = createLabel(Color3.new(0, 1, 0), 1, 15)
    nL.Text = char.Name
    
    local hL = createLabel(Color3.new(1, 1, 1), 2, 12)
    local sL = createLabel(Color3.new(1, 1, 0), 3, 12)

    local function update()
        hL.Text = "HP: " .. math.floor((hum.Health / hum.MaxHealth) * 100) .. "%"
        sL.Text = "STAM: " .. math.floor(char:GetAttribute("Stamina") or 100) .. "%"
    end

    hum:GetPropertyChangedSignal("Health"):Connect(update)
    char:GetAttributeChangedSignal("Stamina"):Connect(update)
    update()
end

task.spawn(function()
    while _G.Name_Active do
        local a = Workspace:FindFirstChild("PLAYERS") and Workspace.PLAYERS:FindFirstChild("ALIVE")
        if a then 
            for _, m in pairs(a:GetChildren()) do 
                if m:IsA("Model") then apply(m) end 
            end 
        end
        task.wait(1.5)
    end
end)
