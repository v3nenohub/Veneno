local Workspace = game:GetService("Workspace")

if _G.DoorESP_Active then
    _G.DoorESP_Active = false
    for _, v in pairs(Workspace:GetDescendants()) do
        if v.Name == "VENENO" then
            v:Destroy()
        end
    end
    return
end

_G.DoorESP_Active = true

local function applyESP(obj)
    if not obj:FindFirstChild("VENENO") then
        local highlight = Instance.new("Highlight")
        highlight.Name = "VENENO"
        highlight.Adornee = obj
        highlight.FillTransparency = 1
        highlight.OutlineColor = Color3.fromRGB(255, 255, 0)
        highlight.OutlineTransparency = 0
        highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
        highlight.Parent = obj
    end
end

local function scan()
    local maps = Workspace:FindFirstChild("MAPS")
    local gameMap = maps and maps:FindFirstChild("GAME MAP")
    
    if gameMap then
        local doors = gameMap:FindFirstChild("Doors")
        if doors then
            for _, obj in ipairs(doors:GetDescendants()) do
                if (obj.Name:find("Door Base") or obj.Name:find("Door")) and obj:IsA("BasePart") then
                    if not obj:FindFirstAncestor("LockedDoor") then
                        applyESP(obj)
                    end
                end
            end
        end

        local doubleDoors = gameMap:FindFirstChild("Double Doors")
        if doubleDoors then
            for _, d in ipairs(doubleDoors:GetDescendants()) do
                if (d.Name == "Door1" or d.Name == "Door2") and d:IsA("BasePart") then
                    applyESP(d)
                end
            end
        end
    end

    local ignore = Workspace:FindFirstChild("IGNORE")
    if ignore then
        for _, obj in ipairs(ignore:GetDescendants()) do
            if obj.Name == "Door" and obj:IsA("BasePart") then
                applyESP(obj)
            end
        end
    end
end

task.spawn(function()
    while _G.DoorESP_Active do
        scan()
        task.wait(1.5)
    end
end)
